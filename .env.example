# ========================================
# ENVIRONMENT CONFIGURATION FILE
# Bachat Gat Smart Management System
# ========================================
# 
# INSTRUCTIONS:
# 1. Copy this file and rename to .env
# 2. Update the values with your configuration
# 3. Never commit .env to version control
# 4. Add .env to .gitignore
#
# ========================================

# ========================================
# APPLICATION SETTINGS
# ========================================
APP_NAME="Bachat Gat Smart Management"
APP_VERSION="1.0.0"
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=localhost
DB_NAME=bachat_gat_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ========================================
# URL CONFIGURATION
# ========================================
BASE_URL=http://localhost/bachat_gat/

# ========================================
# SECURITY SETTINGS
# ========================================
SESSION_TIMEOUT=1800
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900
PASSWORD_MIN_LENGTH=6

# ========================================
# FILE UPLOAD SETTINGS
# ========================================
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
MAIL_ENABLED=false
MAIL_FROM_EMAIL=noreply@bachatgat.com
MAIL_FROM_NAME="Bachat Gat"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls

# ========================================
# SMS CONFIGURATION (Optional)
# ========================================
SMS_ENABLED=false
SMS_API_KEY=
SMS_SENDER_ID=BACHAT

# ========================================
# BUSINESS SETTINGS
# ========================================
CURRENCY_SYMBOL=₹
CURRENCY_CODE=INR
DEFAULT_INTEREST_RATE=12.00
MIN_LOAN_AMOUNT=5000
MAX_LOAN_AMOUNT=100000
MIN_INSTALLMENT_MONTHS=3
MAX_INSTALLMENT_MONTHS=24

# ========================================
# PAGINATION SETTINGS
# ========================================
RECORDS_PER_PAGE=10
PAGINATION_LINKS=5

# ========================================
# NOTIFICATION SETTINGS
# ========================================
NOTIFY_LOAN_APPROVAL=true
NOTIFY_LOAN_REJECTION=true
NOTIFY_INSTALLMENT_DUE=true
INSTALLMENT_REMINDER_DAYS=3

# ========================================
# LATE FEE CONFIGURATION
# ========================================
LATE_FEE_ENABLED=true
LATE_FEE_PERCENTAGE=2
LATE_FEE_GRACE_DAYS=3

# ========================================
# DASHBOARD SETTINGS
# ========================================
DASHBOARD_REFRESH_INTERVAL=300

# ========================================
# END OF CONFIGURATION
# ========================================
